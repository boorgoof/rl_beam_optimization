                <mxCell id="BaseBeamEnv_body" value="&lt;b&gt;attributes by role&lt;/b&gt;&lt;br&gt;&lt;b&gt;simulator&lt;/b&gt;:&lt;br&gt;&lt;font style=&quot;color: rgb(28, 111, 255);&quot;&gt;# simulator : BeamSimulator&lt;/font&gt;&lt;br&gt;&lt;b&gt;spaces/config&lt;/b&gt;:&lt;br&gt;&lt;font style=&quot;color: rgb(28, 111, 255);&quot;&gt;+ observation_space : Box&lt;br&gt;+ action_space : Box&lt;/font&gt;&lt;br&gt;+ max_steps : int&lt;br&gt;- _reset_std : ndarray&lt;br&gt;&lt;i&gt;observation/action scales from config.adige&lt;/i&gt;&lt;br&gt;&lt;b&gt;episode state&lt;/b&gt;:&lt;br&gt;- _step_count&lt;br&gt;- _current_params&lt;br&gt;- _current_obs&lt;br&gt;- _current_score&lt;br&gt;- _previous_obs&lt;br&gt;- _last_action&lt;br&gt;- _last_reward&lt;br&gt;- _current_result : BeamSimulationResult | None&lt;br&gt;- _params/_obs/_score/_reward/_knn_distance history (render)&lt;br&gt;&lt;b&gt;best step() tracking&lt;/b&gt;:&lt;br&gt;+ best_score : float&lt;br&gt;+ best_params : dict&lt;br&gt;&lt;hr&gt;&lt;b&gt;methods by role&lt;/b&gt;&lt;br&gt;&lt;b&gt;constructor&lt;/b&gt;:&lt;br&gt;+ __init__(max_steps)&lt;br&gt;&lt;b&gt;Gym loop&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;color: rgb(28, 111, 255);&quot;&gt;+ reset(seed=None, options=None)&lt;br&gt;+ step(action)&lt;/font&gt;&lt;br&gt;&lt;b&gt;subclass contract&lt;/b&gt;:&lt;br&gt;&lt;font style=&quot;color: rgb(28, 111, 255);&quot;&gt;&lt;i&gt;abstract&lt;/i&gt; # _build_simulator() : BeamSimulator&lt;/font&gt;&lt;br&gt;&lt;b&gt;simulation&lt;/b&gt;:&lt;br&gt;+ evaluate_params(params) : float&lt;br&gt;- _result_to_obs_score_info(result)&lt;br&gt;&lt;i&gt;uses select_observation_stages(result.beam_states)&lt;/i&gt;&lt;br&gt;&lt;b&gt;rendering&lt;/b&gt;:&lt;br&gt;&lt;font style=&quot;color: rgb(28, 111, 255);&quot;&gt;+ render(mode=&quot;human&quot;)&lt;/font&gt;&lt;br&gt;- _obs_to_stage_frame(obs)&lt;br&gt;- _feature_improved(feature,before,after)&lt;br&gt;- _feature_trend(feature,before,after)&lt;br&gt;- _feature_yli