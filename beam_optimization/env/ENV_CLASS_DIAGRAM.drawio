                <mxCell id="AdigeConfig_body" value="&lt;b&gt;constants by role&lt;/b&gt;&lt;br&gt;&lt;b&gt;beam state&lt;/b&gt;:&lt;br&gt;+ BEAM_STATE_FEATURES / BEAM_STATE_DIM / INITIAL_NPART&lt;br&gt;&lt;b&gt;episode/reward&lt;/b&gt;:&lt;br&gt;+ MAX_STEPS / ERROR_SCORE / SCORE_WEIGHTS&lt;br&gt;&lt;b&gt;machine params&lt;/b&gt;:&lt;br&gt;+ PARAMETERS / PARAM_KEYS / N_PARAMS&lt;br&gt;+ DATASET_SCALE / RESET_SCALE / ACTION_SCALE (global) + hw_min/hw_max per ParameterSpec&lt;br&gt;&lt;b&gt;stages/observation&lt;/b&gt;:&lt;br&gt;+ STAGE_MARKERS / N_OUTPUT_STAGES / N_STAGES&lt;br&gt;+ OBSERVATION_STAGE_MASK&lt;br&gt;+ observation_stage_indices() / labels() / dim()&lt;br&gt;&lt;hr&gt;&lt;b&gt;functions by role&lt;/b&gt;&lt;br&gt;&lt;b&gt;params/actions&lt;/b&gt;:&lt;br&gt;+ default_params()&lt;br&gt;+ sensitivity_vec() / action_step_vec() / reset_std_vec()&lt;br&gt;+ action_bounds()&lt;br&gt;+ params_to_vec(params) / vec_to_params(vec)&lt;br&gt;&lt;b&gt;observation selection&lt;/b&gt;:&lt;br&gt;+ select_observation_stages(stages)&lt;br&gt;+ select_observation_stages_tensor(stages)&lt;br&gt;&lt;b&gt;surrogate tensors&lt;/b&gt;:&lt;br&gt;+ params_to_stage_tensors(params, device)&lt;br&gt;&lt;b&gt;scoring&lt;/b&gt;:&lt;br&gt;+ score(final_beam)&lt;br&gt;+ score_from_vec(vec)&lt;br&gt;+ score_tensor(final_beam_tensor)" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;spacing=8;overflow=fill;fontColor=#333333;fontSize=10;" parent="AdigeConfig" vertex="1" connectable="0">
