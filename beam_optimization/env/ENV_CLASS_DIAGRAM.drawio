                <mxCell id="SurrogateBeamSimulator_body" value="&lt;b&gt;attributes by role&lt;/b&gt;&lt;br&gt;&lt;b&gt;models&lt;/b&gt;:&amp;nbsp;&lt;div&gt;- _ensemble : list[ModularMLP];&amp;nbsp;&lt;/div&gt;&lt;div&gt;+ model : ModularMLP;&amp;nbsp;&lt;/div&gt;&lt;div&gt;- _active_model_index : int&lt;br&gt;&lt;b&gt;data/device&lt;/b&gt;:&amp;nbsp;&lt;/div&gt;&lt;div&gt;+ dataset : BeamDataset;&amp;nbsp;&lt;/div&gt;&lt;div&gt;+ device : torch.device;&amp;nbsp;&lt;/div&gt;&lt;div&gt;- _rng : np.random.Generator [seeded]&lt;br&gt;&lt;b&gt;beam0 sampling&lt;/b&gt;:&amp;nbsp;&lt;/div&gt;&lt;div&gt;- _initial_beam_states : Tensor;&amp;nbsp;&lt;/div&gt;&lt;div&gt;- _episode_beam0 : ndarray&lt;br&gt;&lt;hr&gt;&lt;b&gt;properties&lt;/b&gt;&lt;br&gt;+ ensemble : list[ModularMLP]&lt;br&gt;&lt;hr&gt;&lt;b&gt;methods by role&lt;/b&gt;&lt;br&gt;&lt;b&gt;construction&lt;/b&gt;:&amp;nbsp;&lt;/div&gt;&lt;div&gt;+ __init__(model, dataset, device)&lt;br&gt;&lt;b&gt;ensemble/episode&lt;/b&gt;:&amp;nbsp;&lt;/div&gt;&lt;div&gt;+ sample_model_index(rng=None) : int;&amp;nbsp;&lt;/div&gt;&lt;div&gt;+ set_active_model(index);&amp;nbsp;&lt;/div&gt;&lt;div&gt;+ sample_beam0(rng=None) : ndarray;&amp;nbsp;&lt;/div&gt;&lt;div&gt;+ set_episode_beam0(beam0);&amp;nbsp;&lt;/div&gt;&lt;div&gt;+ reset_context(rng=None)&lt;br&gt;&lt;b&gt;simulation&lt;/b&gt;:&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: rgb(28, 111, 255);&quot;&gt;+ simulate(params) : BeamSimulationResult;&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: rgb(28, 111, 255);&quot;&gt;+ forward_differentiable(model, beam0, stage_params_grad)&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;module function&lt;/b&gt;:&amp;nbsp;&lt;/div&gt;&lt;div&gt;run_surrogate_forward(model, beam0, params, device)&lt;/div&gt;" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;spacing=8;overflow=fill;fontSize=10;" parent="SurrogateBeamSimulator" vertex="1" connectable="0">
