                <mxCell id="DstFile_body" value="&lt;b&gt;reads TraceWin distribution files&lt;/b&gt;&lt;br&gt;+ filename&lt;br&gt;+ Np / Ib / freq / mass&lt;br&gt;- _columns = [x, xp, y, yp, phi, E]&lt;br&gt;- _data&lt;br&gt;&lt;hr&gt;&lt;b&gt;methods&lt;/b&gt;&lt;br&gt;+ __getitem__(key)&lt;br&gt;+ __setitem__(key, value)&lt;br&gt;+ append(...) / remove(...)&lt;br&gt;+ save(...)&lt;br&gt;+ subplot(...)" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;spacing=8;fontSize=10;overflow=fill;fontColor=#333333;" parent="DstFile" vertex="1" connectable="0">
