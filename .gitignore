# Repository scope
# Keep this repository focused on the beam_optimization package.
/*
!/.gitignore
!/beam_optimization/
!/beam_optimization/**

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
/venv/
/env/
/.venv/
/.env/
beam_optimization/.venv/

# Jupyter
.ipynb_checkpoints/

# IDE / local tools
.vscode/
.idea/
.claude/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Large files / books
*.pdf
!thesis_proposal.pdf

# Training artifacts
beam_optimization/runs/
beam_optimization/results/
beam_optimization/**/calc/
beam_optimization/**/sensitivity_calc/
checkpoints/
*.pt
*.pth
*.ckpt

# Versioned baseline data/models
!beam_optimization/env/dataset/base/dataset_base.pt
!beam_optimization/env/surrogate_env/surrogate/trained_models/
!beam_optimization/env/surrogate_env/surrogate/trained_models/base/
!beam_optimization/env/surrogate_env/surrogate/trained_models/base/*.pt
!beam_optimization/env/surrogate_env/surrogate/trained_models/updated/
!beam_optimization/env/surrogate_env/surrogate/trained_models/updated/*.pt

# Logs
*.log
*.csv

# Local TraceWin binary (large/licensed executable)
beam_optimization/env/tracewin_env/tracewin/pyTraceWin_wrapper/TraceWin_program/TraceWin

# Local launcher with machine-specific permissions/user setup
beam_optimization/env/tracewin_env/tracewin/pyTraceWin_wrapper/run_tracewin_with_permissions.sh

# Local TraceWin physical workspace: input distributions and field maps are large.
# Keep it on disk, but do not store it in normal Git history.
beam_optimization/env/tracewin_env/tracewin/TraceWin_workspace/

# Data
data/raw/
*.h5
*.hdf5
*.npy
*.npz


#cartelle
file_utili
